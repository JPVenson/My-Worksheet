// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/dotnet
{
	"name": "C# (.NET)",
	// "image": "mcr.microsoft.com/devcontainers/dotnet:dev-10.0",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		// "devwasm.azurecr.io/dev-wasm/dev-wasm-feature/dotnet-wasi:0": {},
		"ghcr.io/devcontainers/features/dotnet:2": {
			"version": "none",
			"dotnetRuntimeVersions": "10.0",
			"aspNetCoreRuntimeVersions": "10.0",
			"additionalVersions": "9.0"
		},
		"ghcr.io/devcontainers-extra/features/apt-packages": {
			"preserve_apt_list": false,
			"packages": [
				"libfontconfig1",
				"python3",
				"fonts-liberation",
				"libasound2t64",
				"libatk-bridge2.0-0t64",
				"libatk1.0-0t64",
				"libatspi2.0-0t64",
				"libcairo2",
				"libcups2t64",
				"libdbus-1-3",
				"libdrm2",
				"libffi8",
				"libgbm1",
				"libglib2.0-0t64",
				"libgtk-3-0t64",
				"libicu74",
				"libnspr4",
				"libnss3",
				"libpango-1.0-0",
				"libx11-6",
				"libx264-164",
				"libxcb1",
				"libxcomposite1",
				"libxdamage1",
				"libxext6",
				"libxfixes3",
				"libxrandr2",
			]
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"dockerDashComposeVersion": "v2"
		},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/eitsupi/devcontainer-features/jq-likes:2": {}
	},
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [
		5000,
		5001,
		3306,
		"pgadmin:8081"
	],
	"portsAttributes": {
		"5001": {
			"protocol": "https"
		},
		"8081": {
			"label": "pgAdmin",
			"onAutoForward": "notify",
			"requireLocalPort": true
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-dotnettools.csharp",
				"ms-dotnettools.csdevkit",
				"ms-dotnettools.blazorwasm-companion",
				"eamodio.gitlens",
				"glenn2223.live-sass",
				"DominicVonk.vscode-resx-editor"
			]
		}
	},
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "dotnet restore; dotnet workload install wasm-tools; dotnet dev-certs https --trust",
	"postCreateCommand": "dotnet workload restore; dotnet restore; dotnet workload update",
	"postStartCommand": "sudo mkdir -p /etc/docker && echo '{\"dns\": [\"10.255.255.254\"]}' | sudo tee /etc/docker/daemon.json > /dev/null && sudo kill -9 $(cat /var/run/docker.pid 2>/dev/null || pgrep dockerd) 2>/dev/null; sleep 2; sudo dockerd > /tmp/dockerd.log 2>&1 &",
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}