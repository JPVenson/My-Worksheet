{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "hosted": true,
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/MyWorksheet.Website/Server/bin/Debug/net10.0/MyWorksheet.Website.Server.dll",           
            "cwd": "${workspaceFolder}/MyWorksheet.Website/Server",
            "internalConsoleOptions": "openOnSessionStart",    
            "env": {                
              "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "url": "https://localhost:5001;http://localhost:5000",       
        },
        // {
        //     "name": ".NET Attach",
        //     "type": "coreclr",
        //     "request": "attach",
        //     "processId": "${command:pickProcess}"
        // }
    ],
    "env": {
        "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
    }
}