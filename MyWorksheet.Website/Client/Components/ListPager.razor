@typeparam T

@{
	ReevaluateRanges();
}

<nav class="d-flex flex-row">
	<ul class="pagination">
		<li class="page-item @When(ItemsSource.Page == 1, "disabled")">
			<a class="page-link" tabindex="-1" @onclick="() => LoadPage(ItemsSource.Page - 1)">Previous</a>
		</li>
		@for (int i = 0; i < DisplayStartRange; i++)
		{
			var pageNo = (ItemsSource.Page) - (DisplayStartRange - i);
			<li class="page-item" @onclick="() => LoadPage(pageNo)">
				<a class="page-link">@pageNo</a>
			</li>
		}

		<li class="page-item disabled">
			<a class="page-link active">@ItemsSource.Page</a>
		</li>

		@for (int i = 0; i < DisplayEndRange; i++)
		{
			var pageNo = ItemsSource.Page + 1 + i;
			<li class="page-item" @onclick="() => LoadPage(pageNo)">
				<a class="page-link">@pageNo</a>
			</li>
		}

		<li class="page-item @When(ItemsSource.Page == ItemsSource.MaxPages, "disabled")">
			<a class="page-link" @onclick="() => LoadPage(ItemsSource.Page + 1)">Next</a>
		</li>
	</ul>
	<span class="btn-alike">
		Total: @ItemsSource.TotalItemsCount
	</span>
</nav>