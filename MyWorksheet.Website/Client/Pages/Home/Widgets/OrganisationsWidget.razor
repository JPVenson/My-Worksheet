@inherits WidgetViewBase
@using MyWorksheet.Website.Shared.ViewModels.ApiResultModels.Accounting.Organisation
@attribute [DashboardWidget("Orgs", "Dashboard/Widget.Orgs.Name", "Dashboard/Widget.Orgs.Description", "fas fa-building", true)]

@if (Organizations == null)
{
	<div class="d-flex justify-content-center p-4">
		<div class="spinner-border spinner-border-sm text-primary" role="status"></div>
	</div>
	return;
}

@if (!Organizations.Any())
{
	<div class="p-4 text-center text-muted">
		<i class="fas fa-building fa-2x mb-2 d-block opacity-50"></i>
		<Translatable Key="Dashboard/Widget.Orgs.Empty" />
	</div>
	return;
}

<div class="p-3">
	<div class="row g-2">
		@foreach (var org in Organizations)
		{
			<div class="col-6">
				<a href="/Organization/@org.OrganisationId" class="org-card text-decoration-none d-flex">
					<div class="org-card-icon">
						<i class="fas fa-building"></i>
					</div>
					<div class="org-card-name ms-1">@org.Name</div>
				</a>
			</div>
		}
	</div>
</div>

<div class="px-3 pb-2 text-end">
	<a href="/Organizations" class="btn btn-sm btn-outline-secondary">
		<Translatable Key="Dashboard/Widget.Orgs.ViewAll" />
		<i class="fas fa-chevron-right ms-1"></i>
	</a>
</div>
